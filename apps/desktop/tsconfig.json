{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist-ts",
    "rootDir": "./electron",
    "strict": true,
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["electron/core/**/*.ts"],
  "exclude": ["node_modules"]
}
