{
  "name": "@multi-publish/desktop",
  "version": "1.2.0",
  "description": "\u591a\u5e73\u53f0\u5185\u5bb9\u4e00\u952e\u53d1\u5e03\u684c\u9762\u5de5\u5177 (Electron + RpaViewManager)",
  "author": "Colin Chiu <colin.chiu@colinchiu.com>",
  "main": "electron/main.js",
  "scripts": {
    "dev:vue": "vite",
    "dev:electron": "wait-on http://localhost:5174 && electron .",
    "dev": "concurrently \"npm run dev:vue\" \"npm run dev:electron\"",
    "build:vue": "vite build",
    "build": "npm run build:vue && electron-builder",
    "build:win": "npm run build:vue && electron-builder --win --x64",
    "build:dir": "npm run build:vue && electron-builder --dir",
    "preview": "vite preview",
    "test": "jest --colors"
  },
  "keywords": [
    "multi-publish",
    "rpa",
    "wechat"
  ],
  "license": "MIT",
  "dependencies": {
    "@multi-publish/shared-utils": "*",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vueup/vue-quill": "^1.5.3",
    "axios": "^1.9.0",
    "better-sqlite3": "^12.10.0",
    "electron-updater": "^6.8.9",
    "element-plus": "^2.9.0",
    "form-data": "^4.0.0",
    "fuse.js": "^7.4.2",
    "pinia": "^2.3.0",
    "vite": "^6.3.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "electron": "33.4.0",
    "electron-builder": "^25.1.8",
    "jest": "^30.4.2",
    "wait-on": "^8.0.0",
    "js-yaml": "^4.2.0"
  },
  "build": {
    "appId": "com.colinchiu.multi-publish",
    "productName": "Multi-Publish",
    "directories": {
      "output": "dist-electron"
    },
    "electronVersion": "33.4.0",
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "config/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": null,
      "sign": false,
      "signAndEditExecutable": false,
      "signDlls": false,
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "artifactName": "${productName}.Setup.${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "Colinchiu007",
      "repo": "Multi-Publish"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": null,
      "artifactName": "${productName}-${version}-mac.${ext}",
      "category": "public.app-category.productivity",
      "hardenedRuntime": false
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": null,
      "artifactName": "${productName}-${version}-${arch}.AppImage",
      "category": "Network"
    }
  }
}
