{
    "name": "@multi-publish/desktop",
    "version": "2.3.53",
    "description": "婢舵艾閽╅崣鏉垮敶鐎归€涚闁款喖褰傜敮鍐╊攽闂堛垻顏?(Electron + RpaViewManager)",
    "author": "Colin Chiu <colin.chiu@colinchiu.com>",
    "main": "electron/main.js",
    "scripts": {
        "dev:vue": "vite",
        "dev:electron": "npm run build:preload && wait-on http://localhost:5174 && electron .",
        "dev": "concurrently \"npm run dev:vue\" \"npm run dev:electron\"",
        "build:preload": "node scripts/build-preload.js",
        "build:vue": "npm run build:preload && vite build",
        "build": "npm run build:vue && electron-builder",
        "build:win": "npm run build:vue && electron-builder --win --x64",
        "build:dir": "npm run build:vue && electron-builder --dir",
        "preview": "vite preview",
        "test": "vitest run",
        "build:ts": "tsc",
        "lint": "eslint electron/ src/ --no-ignore --max-warnings 300",
        "lint:fix": "eslint electron/ src/ --no-ignore --fix --max-warnings 300",
        "format": "prettier --check \"electron/**/*.js\" \"src/**/*.{js,vue}\"",
        "format:write": "prettier --write \"electron/**/*.js\" \"src/**/*.{js,vue}\"",
        "check:ts": "tsc -p tsconfig.check.json --noEmit",
        "check:all": "npm run check:ts && npm run lint && npm run test",
        "test:visual": "node tests/visual-testing/views/all-views.visual.test.js",
        "test:workflow": "node tests/visual-testing/workflows/all-workflows.visual.test.js",
        "test:visual:ci": "node tests/visual-testing/scripts/visual-ci.js",
        "test:visual:update-baseline": "cross-env UPDATE_BASELINE=1 node tests/visual-testing/scripts/run-pixel-tests.js",
        "test:visual:quick": "node tests/visual-testing/views/all-views.visual.test.js --single home-default",
        "test:all:visual": "node tests/visual-testing/views/all-views.visual.test.js && node tests/visual-testing/views/supplementary-views.visual.test.js && node tests/visual-testing/workflows/all-workflows.visual.test.js && node tests/visual-testing/workflows/supplementary-workflows.visual.test.js",
        "test:visual:pixel": "node tests/visual-testing/scripts/run-pixel-tests.js",
        "test:visual:agent": "node tests/visual-testing/scripts/agent-visual-judge.js",
        "test:ai:autonomous": "node ../../packages/ai-autonomous-tester/scripts/run-autonomous.js",
        "test:visual:supplement": "node tests/visual-testing/views/supplementary-views.visual.test.js",
        "test:workflow:supplement": "node tests/visual-testing/workflows/supplementary-workflows.visual.test.js",
        "test:functional": "node tests/visual-testing/functional-test.js",
        "test:autonomous-loop": "node tests/visual-testing/autonomous-loop.js",
        "test:full-regression": "node tests/visual-testing/autonomous-loop.js --max-rounds 3",
        "test:fix-loop": "node tests/visual-testing/autonomous-fix-loop.js",
        "test:enforce": "node tests/visual-testing/autonomous-enforce-loop.js",
        "test:mutation": "cd ../.. && npx stryker run stryker.conf.json",
        "test:mutation:identity": "stryker run stryker.identity.conf.json",
        "test:coverage": "vitest run --coverage --maxWorkers=1 --no-file-parallelism",
        "test:fault": "cross-env INJECT_FAULTS=1 vitest run electron/tests/fault-injection.test.js",
        "test:monkey": "vitest run electron/tests/monkey.test.js",
        "test:quality": "npm run test:fault && npm run test:monkey",
        "test:e2e": "node tests/e2e/helpers/run-all.js",
        "test:e2e:identity": "node tests/e2e/identity-menu.e2e.js",
        "test:e2e:routes": "node tests/e2e/helpers/run-all.js routes",
        "test:e2e:flows": "node tests/e2e/helpers/run-all.js flows",
        "test:e2e:b1": "node tests/e2e/specs/b1-core-publish.js",
        "test:startup": "vitest run --config vitest.smoke.config.js",
        "test:preload:sandbox": "npm run build:preload && node scripts/verify-preload-sandbox.js"
    },
    "keywords": [
        "multi-publish",
        "rpa",
        "wechat"
    ],
    "license": "MIT",
    "dependencies": {
        "@element-plus/icons-vue": "^2.3.2",
        "@logto/client": "3.1.8",
        "@multi-publish/ai-writer": "*",
        "@multi-publish/api-publish-engine": "*",
        "@multi-publish/rpa-engine": "*",
        "@multi-publish/shared-utils": "*",
        "@vitejs/plugin-vue": "^5.2.0",
        "@vueup/vue-quill": "^1.5.3",
        "axios": "^1.9.0",
        "electron-updater": "^6.8.9",
        "element-plus": "^2.14.2",
        "fuse.js": "^7.4.2",
        "pinia": "^2.3.0",
        "sql.js": "^1.11.0",
        "vite": "^6.3.0",
        "vue": "^3.5.0",
        "vue-router": "^4.5.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@vitest/coverage-v8": "^4.1.9",
        "@vue/test-utils": "^2.4.11",
        "concurrently": "^9.0.0",
        "cross-env": "^10.1.0",
        "electron": "^43.1.1",
        "electron-builder": "^25.1.8",
        "esbuild": "^0.25.12",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.9.2",
        "globals": "^17.7.0",
        "jsdom": "^29.1.1",
        "pixelmatch": "^5.3.0",
        "playwright": "^1.61.1",
        "pngjs": "^7.0.0",
        "prettier": "^3.9.4",
        "tesseract.js": "^5.1.1",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9",
        "vue-eslint-parser": "^10.4.1",
        "wait-on": "^8.0.0"
    },
    "build": {
        "beforePack": "scripts/before-pack.js",
        "appId": "com.colinchiu.multi-publish",
        "productName": "Multi-Publish",
        "directories": {
            "output": "dist-electron"
        },
        "electronVersion": "43.1.1",
        "npmRebuild": false,
        "files": [
            "dist/**/*",
            "electron/**/*",
            "node_modules/**/*",
            "package.json"
        ],
        "extraResources": [
            {
                "from": "../../config",
                "to": "config"
            },
            {
                "from": ".playwright-browsers",
                "to": "playwright-browsers"
            },
            {
                "from": "../../packages/remotion-composer",
                "to": "packages/remotion-composer",
                "filter": [
                    "**/*",
                    "!node_modules/**"
                ]
            }
        ],
        "win": {
            "target": "nsis",
            "icon": null,
            "sign": false,
            "signAndEditExecutable": false,
            "signDlls": false,
            "requestedExecutionLevel": "asInvoker"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "deleteAppDataOnUninstall": true,
            "artifactName": "${productName}.Setup.${version}.${ext}"
        },
        "publish": {
            "provider": "github",
            "owner": "Colinchiu007",
            "repo": "Multi-Publish"
        }
    }
}
