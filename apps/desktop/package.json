{
  "name": "@multi-publish/desktop",
  "version": "2.0.0",
  "description": "貔ｶ豌ｬ髓ｩ骰呎攸蜚ｴ轢ｹ騾帷ｫｴ髢ｿ裵ｼ蠖ら髪蜀ｩ赶鷹来繹莨宣函?(Electron + RpaViewManager)",
  "author": "Colin Chiu <colin.chiu@colinchiu.com>",
  "main": "electron/main.js",
  "scripts": {
    "dev:vue": "vite",
    "dev:electron": "wait-on http://localhost:5174 && electron .",
    "dev": "concurrently \"npm run dev:vue\" \"npm run dev:electron\"",
    "build:vue": "vite build",
    "build": "npm run build:vue && electron-builder",
    "build:win": "npm run build:vue && electron-builder --win --x64",
    "build:dir": "npm run build:vue && electron-builder --dir",
    "preview": "vite preview",
    "test": "tsc && jest --colors",
    "test:vue": "vitest run",
    "build:ts": "tsc"
  },
  "keywords": [
    "multi-publish",
    "rpa",
    "wechat"
  ],
  "license": "MIT",
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@multi-publish/shared-utils": "*",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vueup/vue-quill": "^1.5.3",
    "axios": "^1.9.0",
    "electron-updater": "^6.8.9",
    "element-plus": "^2.14.2",
    "form-data": "^4.0.0",
    "fuse.js": "^7.4.2",
    "pinia": "^2.3.0",
    "sql.js": "^1.11.0",
    "vite": "^6.3.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "concurrently": "^9.0.0",
    "electron": "33.4.0",
    "electron-builder": "^25.1.8",
    "jest": "^30.4.2",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.colinchiu.multi-publish",
    "productName": "Multi-Publish",
    "directories": {
      "output": "dist-electron"
    },
    "electronVersion": "33.4.0",
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "config/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": null,
      "sign": false,
      "signAndEditExecutable": false,
      "signDlls": false,
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "artifactName": "${productName}.Setup.${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "Colinchiu007",
      "repo": "Multi-Publish"
    }
  }
}
