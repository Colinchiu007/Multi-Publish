# 业务 API 生产环境变量模板。这里只列名称和安全占位符，不填真实 Secret。
NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# shadow 阶段 required=false；切换 required 前运行 validate-production-config --phase required。
IDENTITY_AUTH_ENABLED=true
IDENTITY_AUTH_REQUIRED=false
BUSINESS_DATABASE_AUTO_MIGRATE=false
# 默认使用仓库 `migrations/postgresql`；独立打包时可指向只读 migration 目录。
BUSINESS_DATABASE_MIGRATIONS_DIR=

# Logto issuer 可填 https://id.example.com 或完整 /oidc issuer。
LOGTO_ENDPOINT=
LOGTO_API_RESOURCE=https://api.example.com

# 必须与 Logto DB 分离；Secret Store 注入，不要提交到仓库。
BUSINESS_DATABASE_URL=
LOGTO_DATABASE_URL=
LOGTO_WEBHOOK_SIGNING_KEY=
ENTITLEMENT_KEY_ID=
ENTITLEMENT_PRIVATE_KEY=

LOGTO_JWKS_CACHE_TTL=300
LOGTO_WEBHOOK_MAX_EVENT_AGE_SECONDS=900
LOGTO_WEBHOOK_MAX_FUTURE_SKEW_SECONDS=300
MAX_RPM=100
ENABLE_SCHEDULE=false
