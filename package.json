{
  "name": "multi-publish",
  "version": "2.3.53",
  "private": true,
  "description": "多平台内容一键发布 — Monorepo",
  "scripts": {
    "dev": "npm run dev -w @multi-publish/desktop",
    "build": "npm run build -w @multi-publish/desktop",
    "build:win": "npm run build:win -w @multi-publish/desktop",
    "test": "npm run test --workspaces --if-present",
    "clean": "rm -rf apps/*/node_modules packages/*/node_modules node_modules",
    "check:deps": "depcheck --ignore-dirs=dist,node_modules,.playwright-browsers --ignores=@vitejs/*,vite,app-builder-bin,electron,@jridgewell/trace-mapping,cheerio,remotion,@stryker-mutator/core,@stryker-mutator/vitest-runner,pinia,playwright",
    "check:circular": "madge --warning --circular apps/desktop/electron/main.js",
    "test:rpa-selectors": "cd packages/rpa-engine && npx vitest run tests/platform-selectors.test.js tests/platform-selectors-cross-platform.test.js",
    "test:ai-autonomous-tester": "npm test -w @multi-publish/ai-autonomous-tester"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "keywords": [
    "multi-publish",
    "rpa",
    "wechat"
  ],
  "license": "MIT",
  "dependencies": {
    "@jridgewell/trace-mapping": "^0.3.25",
    "app-builder-bin": "5.0.0-alpha.10",
    "cheerio": "^1.2.0",
    "electron": "^43.1.1",
    "remotion": "^4.0.484"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "depcheck": "^1.4.7",
    "madge": "^8.0.0",
    "pinia": "^3.0.0",
    "playwright": "^1.61.1"
  }
}
