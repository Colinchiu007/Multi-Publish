{
  "name": "multi-publish",
  "version": "0.1.0",
  "description": "多平台内容一键发布桌面工具 (Electron + Playwright)",
  "main": "electron/main.js",
  "scripts": {
    "dev:vue": "vite --config vite.config.js",
    "dev:electron": "wait-on http://localhost:5174 && electron .",
    "dev": "concurrently \"npm run dev:vue\" \"npm run dev:electron\"",
    "build:vue": "vite build",
    "build": "npm run build:vue && electron-builder",
    "preview": "vite preview"
  },
  "keywords": ["multi-publish", "rpa", "wechat"],
  "license": "MIT",
  "dependencies": {
    "element-plus": "^2.9.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "vite": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "concurrently": "^9.0.0",
    "wait-on": "^8.0.0",
    "playwright": "^1.52.0"
  },
  "build": {
    "appId": "com.colinchiu.multi-publish",
    "productName": "Multi-Publish",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "python/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}