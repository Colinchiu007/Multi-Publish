{
  "name": "multi-publish",
  "version": "1.0.4",
  "description": "多平台内容一键发布桌面工具 (Electron + Playwright)",
  "main": "electron/main.js",
  "scripts": {
    "dev:vue": "vite --config vite.config.js",
    "dev:electron": "wait-on http://localhost:5174 && electron .",
    "dev": "concurrently \"npm run dev:vue\" \"npm run dev:electron\"",
    "build:vue": "vite build",
    "build": "npm run build:vue && electron-builder",
    "build:win": "npm run build:vue && electron-builder --win --x64",
    "build:dir": "npm run build:vue && electron-builder --dir",
    "preview": "vite preview"
  },
  "keywords": ["multi-publish", "rpa", "wechat"],
  "license": "MIT",
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "@vueup/vue-quill": "^1.5.3",
    "electron-updater": "^6.8.9",
    "element-plus": "^2.9.0",
    "pinia": "^2.3.0",
    "playwright": "^1.52.0",
    "vite": "^6.3.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.colinchiu.multi-publish",
    "productName": "Multi-Publish",
    "directories": {
      "output": "dist-electron"
    },
    "publish": {
      "provider": "github",
      "owner": "Colinchiu007",
      "repo": "Multi-Publish",
      "releaseType": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "python/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": null,
      "sign": false,
      "artifactName": "${productName}.Setup.${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}