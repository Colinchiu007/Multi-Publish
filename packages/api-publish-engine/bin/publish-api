#!/usr/bin/env node
/**
 * publish-api — CLI 入口
 * 启动 PublishApiServer HTTP 服务
 * 使用: node bin/publish-api [--port 3000] [--dry-run]
 */
const { PublishApiServer } = require("../src/publish-api-server");

var args = process.argv.slice(2);
var port = 3000;
var dryRun = false;

for (var i = 0; i < args.length; i++) {
  if (args[i] === "--port" && i + 1 < args.length) port = parseInt(args[i + 1], 10) || port;
  if (args[i] === "--dry-run") dryRun = true;
  if (args[i] === "--help" || args[i] === "-h") {
    console.log("publish-api — Multi-Publish API 服务");
    console.log("");
    console.log("  使用: node bin/publish-api [选项]");
    console.log("");
    console.log("  选项:");
    console.log("    --port <port>    监听端口 (默认 3000)");
    console.log("    --dry-run        模拟模式 (不真实发布)");
    console.log("    --help, -h       显示帮助");
    process.exit(0);
  }
}

var server = new PublishApiServer({ dryRun: dryRun });
server.start(port).then(function(actualPort) {
  console.log("[publish-api] PublishApiServer 已启动");
  console.log("[publish-api]   端口: " + actualPort);
  console.log("[publish-api]   模式: " + (dryRun ? "DRY-RUN" : "LIVE"));
  console.log("[publish-api]   平台: GET /api/v1/platforms");
  console.log("[publish-api]   发布: POST /api/v1/publish");
  console.log("[publish-api]   批量: POST /api/v1/batch-publish");
  console.log("[publish-api]   健康: GET /api/v1/health");
  console.log("[publish-api] 按 Ctrl+C 停止");
}).catch(function(err) {
  console.error("[publish-api] 启动失败:", err.message);
  process.exit(1);
});