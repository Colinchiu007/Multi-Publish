#!/usr/bin/env node
/**
 * publish-api — CLI 入口
 * 启动 PublishApiServer HTTP 服务
 *
 * 配置加载顺序（低 → 高）:
 *   默认值 < 配置文件 < 环境变量 < CLI 参数
 *
 * 使用:
 *   publish-api [--port 3000] [--dry-run] [--api-key xxx] [--max-rpm 100]
 *   publish-api --config ./my-config.json
 *
 * 环境变量: PORT, DRY_RUN, API_KEY, MAX_RPM, ENABLE_SCHEDULE
 */
const { PublishApiServer } = require("../src/publish-api-server");
const { loadConfig, parseCLI } = require("../src/config-loader");
const { createLogtoRuntime } = require("../src/auth/logto-runtime");
const path = require("path");

const HELP_TEXT = [
  "publish-api - 启动多平台发布 HTTP API",
  "",
  "用法:",
  "  publish-api [--port 3000] [--dry-run] [--api-key <key>] [--max-rpm 100]",
  "  publish-api --config ./publish-api.config.json",
  "",
  "选项:",
  "  -h, --help             显示帮助并退出",
  "  --port <port>          监听端口，默认 3000",
  "  --dry-run              启用试运行模式",
  "  --api-key <key>        设置兼容模式 API key",
  "  --max-rpm <count>      设置每分钟请求上限",
  "  --enable-schedule      启用定时发布",
  "  --config <path>        读取 JSON 配置文件",
].join("\n");

function findConfigFile() {
  // 检查 --config CLI 参数
  var args = process.argv.slice(2);
  for (var i = 0; i < args.length; i++) {
    if (args[i] === "--config" && i + 1 < args.length) {
      return args[i + 1];
    }
  }
  // 检查默认路径
  var candidates = [
    path.resolve("publish-api.config.json"),
    path.resolve("config/publish-api.json"),
  ];
  for (var j = 0; j < candidates.length; j++) {
    try { if (require("fs").statSync(candidates[j]).isFile()) return candidates[j]; }
    catch(e) { /* not found */ }
  }
  return null;
}

async function main() {
  var args = process.argv.slice(2);
  if (args.includes("--help") || args.includes("-h")) {
    console.log(HELP_TEXT);
    return;
  }
  var configFile = findConfigFile();
  // ???? platforms.yaml???????????
  var yamlPath = path.resolve(__dirname, "..", "..", "..", "config", "platforms.yaml");
  try {
    if (require("fs").statSync(yamlPath).isFile()) {
      var yaml = require("js-yaml");
      var raw = require("fs").readFileSync(yamlPath, "utf8");
      var cfg = yaml.load(raw);
      if (cfg && cfg.platforms) {
        var apiCount = Object.values(cfg.platforms).filter(function(p) { return p && p.has_api; }).length;
        var allCount = Object.keys(cfg.platforms).length;
        console.log("[publish-api] Loaded platforms.yaml: " + allCount + " platforms, " + apiCount + " API-capable");
      }
    }
  } catch(e) { /* platforms.yaml not available, that is OK */ }
  var config = loadConfig({
    configFile: configFile,
    readEnv: true,
    cliArgs: parseCLI()
  });

  var identityRuntime = await createLogtoRuntime({ env: process.env });
  var server = new PublishApiServer({
    dryRun: config.dryRun,
    apiKey: config.apiKey,
    maxRpm: config.maxRpm,
    enableSchedule: config.enableSchedule,
    auditLogFile: config.auditLogFile,
    scheduleFile: config.scheduleFile,
    planFile: config.planFile,
    accessLog: config.accessLog,
    scheduleCheckInterval: config.scheduleCheckInterval,
    logtoVerifier: identityRuntime && identityRuntime.verifier,
    identityAuthRequired: identityRuntime ? identityRuntime.required : false,
    businessIdentityRepository: identityRuntime && identityRuntime.repository,
    entitlementProvider: identityRuntime && identityRuntime.entitlementProvider,
    entitlementSigner: identityRuntime && identityRuntime.entitlementSigner,
    logtoWebhookConsumer: identityRuntime && identityRuntime.webhookConsumer
  });

  try {
    var actualPort = await server.start(config.port);
    var mode = config.dryRun ? "DRY-RUN" : "LIVE";
    var auth = identityRuntime ? "Logto OIDC" : config.apiKey ? "API Key (" + config.apiKey.slice(0, 8) + "...)" : "无";
    var rate = config.maxRpm ? config.maxRpm + " rpm" : "无";
    var sched = config.enableSchedule ? "已启用" : "未启用";

    console.log("[publish-api] PublishApiServer 已启动");
    console.log("[publish-api]   配置文件: " + (configFile || "无"));
    console.log("[publish-api]   端口: " + actualPort);
    console.log("[publish-api]   模式: " + mode);
    console.log("[publish-api]   认证: " + auth);
    console.log("[publish-api]   限流: " + rate);
    console.log("[publish-api]   定时: " + sched);
    console.log("[publish-api] 按 Ctrl+C 停止");

    var shuttingDown = false;
    var shutdown = async function() {
      if (shuttingDown) return;
      shuttingDown = true;
      await server.stop();
      if (identityRuntime) await identityRuntime.close();
    };
    process.once("SIGTERM", shutdown);
    process.once("SIGINT", shutdown);
    process.once("beforeExit", shutdown);
  } catch (err) {
    if (identityRuntime) await identityRuntime.close().catch(function() {});
    throw err;
  }
}

main().catch(function(err) {
    console.error("[publish-api] 启动失败:", err.message);
    process.exit(1);
});
