#!/usr/bin/env node
/**
 * publish-api — CLI 入口
 * 启动 PublishApiServer HTTP 服务
 *
 * 配置加载顺序（低 → 高）:
 *   默认值 < 配置文件 < 环境变量 < CLI 参数
 *
 * 使用:
 *   publish-api [--port 3000] [--dry-run] [--api-key xxx] [--max-rpm 100]
 *   publish-api --config ./my-config.json
 *
 * 环境变量: PORT, DRY_RUN, API_KEY, MAX_RPM, ENABLE_SCHEDULE
 */
const { PublishApiServer } = require("../src/publish-api-server");
const { loadConfig, parseCLI } = require("../src/config-loader");
const path = require("path");

function findConfigFile() {
  // 检查 --config CLI 参数
  var args = process.argv.slice(2);
  for (var i = 0; i < args.length; i++) {
    if (args[i] === "--config" && i + 1 < args.length) {
      return args[i + 1];
    }
  }
  // 检查默认路径
  var candidates = [
    path.resolve("publish-api.config.json"),
    path.resolve("config/publish-api.json"),
  ];
  for (var j = 0; j < candidates.length; j++) {
    try { if (require("fs").statSync(candidates[j]).isFile()) return candidates[j]; }
    catch(e) { /* not found */ }
  }
  return null;
}

(function main() {
  var configFile = findConfigFile();
  var config = loadConfig({
    configFile: configFile,
    readEnv: true,
    cliArgs: parseCLI()
  });

  var server = new PublishApiServer({
    dryRun: config.dryRun,
    apiKey: config.apiKey,
    maxRpm: config.maxRpm,
    enableSchedule: config.enableSchedule,
    auditLogFile: config.auditLogFile,
    scheduleFile: config.scheduleFile,
    planFile: config.planFile,
    accessLog: config.accessLog,
    scheduleCheckInterval: config.scheduleCheckInterval
  });

  server.start(config.port).then(function(actualPort) {
    var mode = config.dryRun ? "DRY-RUN" : "LIVE";
    var auth = config.apiKey ? "API Key (" + config.apiKey.slice(0, 8) + "...)" : "无";
    var rate = config.maxRpm ? config.maxRpm + " rpm" : "无";
    var sched = config.enableSchedule ? "已启用" : "未启用";

    console.log("[publish-api] PublishApiServer 已启动");
    console.log("[publish-api]   配置文件: " + (configFile || "无"));
    console.log("[publish-api]   端口: " + actualPort);
    console.log("[publish-api]   模式: " + mode);
    console.log("[publish-api]   认证: " + auth);
    console.log("[publish-api]   限流: " + rate);
    console.log("[publish-api]   定时: " + sched);
    console.log("[publish-api] 按 Ctrl+C 停止");

    var cleanup = PublishApiServer.registerShutdownSignals(server);
    process.on("beforeExit", cleanup);
  }).catch(function(err) {
    console.error("[publish-api] 启动失败:", err.message);
    process.exit(1);
  });
})();