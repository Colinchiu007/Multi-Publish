{
    "name": "@multi-publish/ai-autonomous-tester",
    "version": "0.12.2",
    "description": "AI ???????????????????????/OCR/DOM???????? Agent ??? LLM ????? API Key???? AI ???144 tests?",
    "main": "index.js",
    "exports": {
        ".": "./index.js",
        "./providers/pixel-diff": "./src/providers/pixel-diff.js",
        "./providers/ocr": "./src/providers/ocr.js",
        "./runners/visual": "./src/runners/visual-runner.js",
        "./runners/functional": "./src/runners/functional-runner.js",
        "./runners/requirements": "./src/runners/requirements-runner.js",
        "./runners/autonomous": "./src/runners/autonomous-runner.js",
        "./orchestrator": "./src/orchestrator.js",
        "./ai-analyzer": "./src/ai-analyzer.js",
        "./fix-engine": "./src/fix-engine.js",
        "./agent/agent-judge": "./src/agent/agent-judge.js",
        "./parsers/prd-parser": "./src/parsers/prd-parser.js",
        "./detectors/feature-detector": "./src/detectors/feature-detector.js",
        "./verifier/requirements-verifier": "./src/verifier/requirements-verifier.js",
        "./utils/path-resolver": "./src/utils/path-resolver.js"
    },
    "scripts": {
        "test": "node --test tests/*.test.js",
        "agent-judge": "node scripts/run-agent-judge.js",
        "agent-judge:openai": "cross-env-shell LLM_PROVIDER=openai node scripts/run-agent-judge.js",
        "agent-judge:anthropic": "cross-env-shell LLM_PROVIDER=anthropic node scripts/run-agent-judge.js",
        "test:watch": "node --test --watch tests/*.test.js",
        "test:coverage": "node --experimental-test-coverage --test tests/*.test.js",
        "test:integration": "node --test tests/orchestrator-integration.test.js",
        "test:all": "node --test tests/*.test.js",
        "test:autonomous:e2e": "node scripts/run-autonomous-e2e.js",
        "test:autonomous:e2e:ci": "set LLM_PROVIDER=openai&& node scripts/run-autonomous-e2e.js",
        "test:autonomous:full": "node scripts/run-autonomous-e2e.js --functional --iterations=3 --docs=\"01-docs/PRD.md,README.md\"",
        "test:autonomous:functional": "node scripts/run-autonomous-e2e.js --skip-server --skip-visual --functional",
        "test:autonomous:multi-doc": "node scripts/run-autonomous-e2e.js --skip-server --skip-visual --docs=\"01-docs/PRD.md,README.md\""
    },
    "keywords": [
        "ai-testing",
        "autonomous-testing",
        "visual-regression",
        "functional-testing",
        "e2e-testing",
        "playwright",
        "pixel-diff",
        "ocr",
        "agent-loop",
        "prd-verification",
        "agent-judge",
        "semantic-coverage",
        "github-actions",
        "ci-cd",
        "pr-comment",
        "coverage-audit"
    ],
    "license": "MIT",
    "dependencies": {
        "playwright": "^1.61.1",
        "resemblejs": "^4.1.0",
        "tesseract.js": "^5.1.1"
    }
}
