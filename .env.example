# Multi-Publish 环境配置
# 复制此文件为 .env 并填入实际值
# .env 已加入 .gitignore，不会提交到仓库

# Python 后端
BACKEND_PORT=8299
BACKEND_HOST=127.0.0.1

# Orchestrator API（用于 Cookie 推送，生产环境使用 https）
ORCHESTRATOR_URL=https://your-orchestrator-domain.com
ORCHESTRATOR_API_KEY=

# 加密主密码（生产环境必填，用于派生 AES 密钥；开发模式可留空使用随机密钥）
MASTER_PASSWORD=

# JWT 签名密钥（生产环境必填；开发模式可留空使用随机密钥）
JWT_SECRET=

# AiWriter API 认证密钥（必填，未设置时服务拒绝启动）
AI_WRITER_API_KEY=

# 兑换码 HMAC 密钥（生产环境必填，未设置时 generate/validate 会抛错）
REDEMPTION_SECRET=

# API Keys（可选）
# TIKHUB_API_KEY=your_key_here

# api-publish-engine 独立服务所需（可选，仅使用 API 模式发布时需要）
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# YOUTUBE_REFRESH_TOKEN=
# TIKTOK_ACCESS_TOKEN=
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=
# OPENAI_API_KEY=
# AI_API_URL=
