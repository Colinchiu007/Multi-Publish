# Multi-Publish 环境配置
# 复制此文件为 .env 并填入实际值
# .env 已加入 .gitignore，不会提交到仓库

# Python 后端
BACKEND_PORT=8299
BACKEND_HOST=127.0.0.1

# Orchestrator API（用于 Cookie 推送，生产环境使用 https）
ORCHESTRATOR_URL=https://your-orchestrator-domain.com
ORCHESTRATOR_API_KEY=

# Logto 用户身份（Native Application + Authorization Code/PKCE）
IDENTITY_AUTH_ENABLED=false
IDENTITY_AUTH_REQUIRED=false
LOGTO_ENDPOINT=https://your-logto-domain.com
LOGTO_APP_ID=
LOGTO_API_RESOURCE=https://api.multi-publish.com
LOGTO_REDIRECT_URI=http://127.0.0.1:16526/auth/callback
LOGTO_SCOPES=openid profile offline_access profile:read publish:submit publish:read account:manage cloud:publish
LOGTO_JWKS_CACHE_TTL=300
BUSINESS_API_URL=https://api.multi-publish.com

# 业务 API PostgreSQL（与 Logto 自身数据库隔离，仅服务端使用）
BUSINESS_DATABASE_URL=postgresql://multi_publish:replace-me@127.0.0.1:5432/multi_publish

# Entitlement 离线快照验证（只配置公钥；私钥仅存在于服务端 Secret Store）
ENTITLEMENT_PUBLIC_KEY=
ENTITLEMENT_KEY_ID=entitlement-2026-01
ENTITLEMENT_OFFLINE_GRACE_SECONDS=604800

# 仅业务服务端使用，禁止打包进 Electron
ENTITLEMENT_PRIVATE_KEY=

# 仅业务服务端使用，禁止打包进 Electron
LOGTO_WEBHOOK_SIGNING_KEY=
LOGTO_WEBHOOK_MAX_EVENT_AGE_SECONDS=900
LOGTO_WEBHOOK_MAX_FUTURE_SKEW_SECONDS=300
LOGTO_M2M_APP_ID=
LOGTO_M2M_APP_SECRET=

# 加密主密码（生产环境必填，用于派生 AES 密钥；开发模式可留空使用随机密钥）
MASTER_PASSWORD=

# JWT 签名密钥（生产环境必填；开发模式可留空使用随机密钥）
JWT_SECRET=

# AiWriter API 认证密钥（必填，未设置时服务拒绝启动）
AI_WRITER_API_KEY=

# 兑换码 HMAC 密钥（生产环境必填，未设置时 generate/validate 会抛错）
REDEMPTION_SECRET=

# API Keys（可选）
# TIKHUB_API_KEY=your_key_here

# api-publish-engine 独立服务所需（可选，仅使用 API 模式发布时需要）
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# YOUTUBE_REFRESH_TOKEN=
# TIKTOK_ACCESS_TOKEN=
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=
# OPENAI_API_KEY=
# AI_API_URL=
